# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OPTIONAL: Specify a default chat ID (if not set, bot works in any chat it's added to)
# Leave empty to allow bot in multiple chats/groups
TELEGRAM_CHAT_ID=

# API Keys (optional - uses public endpoints by default)
COINGECKO_API_KEY=

# Bot Configuration
CHECK_INTERVAL_MINUTES=15
MIN_PROBABILITY_THRESHOLD=70

# Security - Comma-separated user IDs who can use the bot
# Get your user ID from @userinfobot in Telegram
ALLOWED_USER_IDS=123456789,987654321
